# Which provider to use: "ollama" (fully local, no key, no limits, default),
# "gemini" (free tier, no credit card, rate-limited), or "openai" (paid)
LLM_PROVIDER=ollama

# Only needed if LLM_PROVIDER=gemini -- https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Only needed if LLM_PROVIDER=openai -- https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
